{
    "name": "topwire/topwire",
    "type": "typo3-cms-extension",
    "description": "Turbo for TYPO3",
    "homepage": "https://topwire.dev",
    "license": [
        "GPL-2.0-or-later"
    ],
    "authors": [
        {
            "name": "Helmut Hummel",
            "email": "typo3@helhum.io",
            "role": "Developer"
        }
    ],
    "config": {
        "allow-plugins": {
            "typo3/cms-composer-installers": false,
            "typo3/class-alias-loader": false,
            "helhum/composer-mono": true
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "Topwire\\": "Classes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Topwire\\Tests\\": "Tests/"
        }
    },
    "require": {
        "php": ">=8.1",
        "typo3/cms-core": "^12.4.5 || ^13.4",
        "helhum/typo3-console": "^8"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.2",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-deprecation-rules": "^2",
        "phpstan/phpstan-doctrine": "^2",
        "phpstan/phpstan-phpunit": "^2 ",
        "phpstan/phpstan-strict-rules": "^2",
        "saschaegerer/phpstan-typo3": "^2",
        "ssch/typo3-rector": "^3",
        "typo3/cms-composer-installers": "^5",
        "typo3/cms-form": "*",
        "typo3/minimal": "*"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        },
        "typo3/cms": {
            "extension-key": "topwire"
        }
    }
}
